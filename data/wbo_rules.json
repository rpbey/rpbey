       margin-top: 5px;\n         }\n         .match-types button:focus {\n         outline: none;\n         }\n         .detailed-rules {\n         margin-top: 15px;\n         }\n\t\t  }\n      </style>\n\t   \n<style>\n.flex-table {\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n\tmargin: 20px 0;\n}\n\n/* Mobile: each row is vertical, each cell is vertical */\n.flex-table-row {\n  display: flex;\n  flex-direction: column;\n  background: #fafbfc;\n  gap: 10px;\n  width: 100%;\n}\n\n.flex-table-cell {\n  flex: 1 1 auto;\n  display: flex;            /* must be flex for equal-height bodies */\n  flex-direction: column;   /* header above body */\n  min-height: 10px;\n  text-align: left;\n}\n\n/* Heading */\n.cell-heading {\n  padding: 10px 15px;\n  background: #000;\n  font-weight: 700;\n  font-size: 20px;\n  font-family: 'Titillium Web';\n  border-radius: 4px 4px 0 0;\n  color: #fff;\n}\n\n.flex-table.finishes .cell-heading {\n\t    display: flex;\n    justify-content: space-between;\n\t}\n\t\n\t.flex-table.finishes .cell-heading div:nth-child(2) {\nbackground: #fff;\n    color: #333;\n    border-radius: 100px;\n    padding: 0 10px;\n\t}\n\t\n\t.flex-table.finishes li {\n\t\tmargin-bottom: 0px;\n\t}\n\n/* Body expands to fill remaining space */\n.cell-body {\n  padding: 10px 15px;\n  border: 0;\n\tbackground: #efefef;\n  border-radius: 0 0 4px 4px;\n  flex: 1 1 auto;    /* ❗ makes all bodies equal height */\n  min-height: 0;     /* prevents overflow issues */\n  display: flex;\n  flex-direction: column;\n}\n\n.flex-table-cell.attention .cell-heading {\n\tbackground: #fbd5b3;\n\tcolor: #333;\n\t}\n\t\n.flex-table-cell.attention .cell-body {\n\tbackground: #faf0e8;\n\tcolor: #333;\n\t}\n\n\t.cell-body h4:first-child {\n    margin-top: 0;\n}\n\t\n.cell-body p:last-child {\n  margin-bottom: 0;\n}\n\n\t\n.pre-table {\n\tbackground: #efefef;\n    padding: 5px 40px;\n    text-align: center;\n    border-radius: 4px;\n    font-weight: 700;\n    margin-bottom: 10px;\n    font-style: italic;\n\t}\n\t\n/* Desktop: row layout, but cells still flex and stretch */\n@media (min-width: 768px) {\n  .flex-table-row {\n    flex-direction: row;\n  }\n\n  .flex-table-cell {\n    flex: 1 1 0;\n  }\n\t\n\t.flex-table.small .cell-heading, .flex-table-cell.small .cell-body {\n\t\tfont-size: 14px;\n}\n\t.flex-table.small .cell-body {\n\t\tfont-family: 'Source Sans Pro';\n}\n\t}\n\n@media (max-width: 767px) {\n  .cell-body {\n    flex: 0 0 auto;   /* don't stretch, don't shrink */\n    display: block;   /* inline flow behaves normally */\n    min-height: auto; /* avoid collapsing */\n\t}\n\t    .flex-table-row {\n    display: block !important;   /* Stack rows naturally */\n  }\n  .flex-table-cell {\n    width: 100%;                 /* Always full-width */\n    display: block;              /* Stack cells vertically */\n\t  margin-bottom: 10px;\n\t}\n\t \n\t  .battle-type-cell img {\n\t  width: 50%;\nmargin: 5px auto 15px auto;\n  }\n\t\n\t\t  .battle-type-cell img.wbo-deck {\n\t  width: 65%;\n  }\n\t\n\t\t\t  .toc-panel .panel-heading {\n\t\t\t  font-size: 16px;\n\t\t  }\n\n\t\t\t\t  .rules-diff-links a {\n\t\t\t  margin-top: 5px;\n\t\t  }\n\t\n}\n</style>\n\t   \n\t   <script>\n$(window).on(\"load\", function () {\n    function resizeRowToTallestDiv() {\n        if ($(window).width() < 768) {\n            return; // Skip execution on mobile\n        }\n\n        $(\".v-flex-row\").each(function () {\n            var maxHeight = 0;\n\n            // Reset height before recalculating (prevents issues on resize)\n            $(this).height('auto');\n\n            // Find the tallest div inside the row\n            $(this).find('div').each(function () {\n                var thisHeight = $(this).outerHeight();\n                if (thisHeight > maxHeight) {\n                    maxHeight = thisHeight;\n                }\n            });\n\n            // Apply the tallest height to the row\n            $(this).height(maxHeight);\n        });\n    }\n\n    // Run the function once the page fully loads\n    resizeRowToTallestDiv();\n\n    // Also adjust dynamically on window resize\n    $(window).resize(resizeRowToTallestDiv);\n});\n\n</script>\n      <script type=\"text/javascript\" src=\"https://worldbeyblade.org/jscripts/toc_generator2.js?version=10\"></script>\n      <script type=\"text/javascript\">\n         <!--\n             var quickdelete_confirm = \"Are you sure you want to delete this post?\";\n             var quickrestore_confirm = \"Are you sure you want to restore this post?\";\n             var allowEditReason = \"1\";\n             lang.save_changes = \"Save Changes\";\n             lang.cancel_edit = \"Cancel Edit\";\n             lang.quick_edit_update_error = \"There was an error editing your reply:\";\n             lang.quick_reply_post_error = \"There was an error posting your reply:\";\n             lang.quick_delete_error = \"There was an error deleting your reply:\";\n             lang.quick_delete_success = \"The post was deleted successfully.\";\n             lang.quick_delete_thread_success = \"The thread was deleted successfully.\";\n             lang.quick_restore_error = \"There was an error restoring your reply:\";\n             lang.quick_restore_success = \"The post was restored successfully.\";\n             lang.editreason = \"Edit Reason\";\n         // -->\n      </script>\n      <script type=\"text/javascript\" src=\"https://worldbeyblade.org/jscripts/jeditable/jeditable.min.js\"></script>\n      <script type=\"text/javascript\" src=\"https://worldbeyblade.org/jscripts/thread.js?ver=1804\"></script>\n      <script type=\"text/javascript\"></script>\n      <script type=\"text/javascript\" src=\"//cdn.rawgit.com/jackmoore/autosize/3.0.7/dist/autosize.min.js\"></script>\n      <script type=\"text/javascript\" src=\"//cdn.rawgit.com/hammerjs/hammer.js/2.0.4/hammer.min.js\"></script>\n   <meta name=\"description\" content=\"About This Rulebook This rulebook is developed by the 