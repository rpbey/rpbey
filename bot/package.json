{
  "name": "rpb-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Discord bot for RPB community",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "prebuild": "bun run schema:sync && bun run db:generate && bun run gen:entries",
    "gen:entries": "bun scripts/gen-entry-imports.ts",
    "build": "swc -d dist src --config-file .swcrc --strip-leading-paths",
    "build:oxc": "bun scripts/build-oxc.ts",
    "build:bin": "bun scripts/build-bin.ts",
    "test:bin": "bun scripts/test-bin.ts",
    "lint": "oxlint --config .oxlintrc.json src",
    "lint:eslint": "eslint src",
    "lint:fix": "oxlint --config .oxlintrc.json --fix src",
    "start": "bun src/index.ts",
    "schema:sync": "bash ../scripts/sync-prisma-schema.sh",
    "schema:check": "bash ../scripts/sync-prisma-schema.sh --check",
    "db:generate": "bunx --bun prisma generate",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@discordx/di": "^3.3.4",
    "@discordx/importer": "^1.3.3",
    "@discordx/music": "^6.3.3",
    "@discordx/pagination": "^4.4.0",
    "@discordx/utilities": "^8.0.0",
    "@napi-rs/canvas": "^0.1.98",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@twurple/api": "^8.1.3",
    "@twurple/auth": "^8.1.3",
    "@twurple/chat": "^8.1.3",
    "canvacord": "^6.0.4",
    "dayjs": "^1.11.20",
    "discord-api-types": "^0.38.47",
    "discord-html-transcripts": "3.3.0",
    "discord-logs": "^2.2.1",
    "discord-player": "^7.2.0",
    "discord.js": "^14.26.3",
    "discordx": "^11.13.3",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.3",
    "pg": "^8.20.0",
    "play-dl": "^1.9.7",
    "prism-media": "^1.3.5",
    "puppeteer": "^24.41.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "tsyringe": "^4.10.0",
    "turndown": "^7.2.4",
    "undici": "^8.1.0",
    "wavefile": "^11.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "oxlint": "^1.60.0",
    "prisma": "^7.7.0",
    "typescript": "^6.0.3"
  }
}