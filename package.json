{
  "name": "rpb-dashboard",
  "version": "1.0.0",
  "description": "Dashboard officiel de la République Populaire du Beyblade",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev",
    "dev:all": "pnpm run bot:dev & next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build --webpack",
    "start": "NODE_OPTIONS='--max-old-space-size=512' next start",
    "lint": "eslint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "bot:dev": "tsx bot/src/index.ts",
    "bot:build": "tsc -p bot/tsconfig.build.json",
    "bot:start": "cd bot && node dist/index.js",
    "scrape:products": "tsx scripts/sync-products.ts",
    "youtube:subscribe": "tsx scripts/subscribe-youtube.ts",
    "video:studio": "remotion studio src/remotion/index.ts",
    "video:render": "remotion render src/remotion/index.ts BeybladeIntro out.mp4"
  },
