{
  "name": "rpb-dashboard",
  "version": "1.0.0",
  "description": "Dashboard officiel de la République Populaire du Beyblade",
  "private": true,
  "workspaces": [
    "bot",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --bun next dev",
    "dev:all": "bun run bot:dev & bun --bun next dev",
    "build": "next build",
    "start": "bun --bun next start",
    "lint": "eslint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "bun prisma/seed.ts",
    "bot:dev": "bun --watch bot/src/index.ts",
    "bot:build": "bun --filter rpb-bot build",
    "bot:start": "bun bot/src/index.ts",
    "scrape:products": "bun scripts/sync-products.ts",
    "youtube:subscribe": "bun scripts/subscribe-youtube.ts",
    "db:seed-anime": "bun prisma/seed-anime.ts",
    "scrape:anime": "bun scripts/scrape-anime.ts",
    "clean": "rm -rf .next dist bot/dist node_modules/.cache .turbo tsconfig.tsbuildinfo"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
